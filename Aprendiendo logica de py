# rangos de las notas
nota = float(input("introduzca por favor su nota: "))
if 0 <= nota < 5:
    print("su nota es I")
elif 5 <= nota < 7:
    print("usted paso rapando")
elif 7 <= nota < 8:
    print("usted es bueno/a")
elif 8 <= nota < 9:
    print("usted es muy bueno/a")
elif nota <= 10:
    print("usted es el mejor de la clase")
else:
    print("no es una nota valida, solo se aceptan notas entre 0 y 10")

