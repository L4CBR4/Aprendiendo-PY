#Listas — guardar varios datos en una sola variable
#¿Qué problema resuelven?
#Hasta ahora, si querías guardar los nombres de 5 amigos, necesitarías 5 variables sueltas:
# amigo1, amigo2, amigo3... Una lista te permite guardar todos esos datos juntos, 
# en una sola variable, en un orden específico.

frutas = ["manzana", "banana", "fresa"]
print(frutas)

herramientas = ["taladro", "pulidora", "caladora", "lijadora", "pistola para pintar"]
print(herramientas)


repuestos = ["caucho", "remaches 1/4", "tornillos 3/8","cinta reflectiva"]
print(repuestos)

#Se escribe entre corchetes [ ]
#Los elementos van separados por comas
#Pueden ser texto, números, lo que sea — incluso mezclados

#Acceder a un elemento — por índice
#Cada elemento tiene una posición, llamada índice, que empieza en 0 (no en 1 — esto es igual que con range()
frutas = ["manzana", "banana", "fresa"]
print(frutas[0])   # manzana
print(frutas[1])   # banana
print(frutas[2])   # fresa

#Modificar un elemento
frutas[1] = "kiwi"
print(frutas)   # ["manzana", "kiwi", "fresa"]

#Agregar y quitar elementos

frutas.append("uva")       # agrega al final
print(frutas)

frutas.remove("manzana")   # quita ese elemento específico
print(frutas)

#Recorrer una lista con for
for fruta in frutas:
    print(fruta)


#     TUPLAS Una tupla es una lista que se congela apenas la creas 
# — mismo comportamiento para leer datos, pero prohibido modificarla después.

#La única diferencia visible es el símbolo: [ ] para listas, ( ) para tuplas.

frutas_lista = ["manzana", "banana", "fresa"]      # lista
frutas_tupla = ("manzana", "banana", "fresa")      # tupla

print(frutas_lista[0])   # manzana
print(frutas_tupla[0])   # manzana

