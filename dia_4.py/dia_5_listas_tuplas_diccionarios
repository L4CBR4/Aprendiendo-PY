#Diccionarios — datos guardados por "nombre", no por posición
# Un diccionario te deja acceder a los datos
#  por un nombre descriptivo (llamado "clave"), no por número de posición.

persona = {
    "nombre": "Camila",
    "edad": 25,
    "ciudad": "Bogotá"
}
# Se escribe entre llaves { }
# Cada dato es un par clave: valor
#"nombre", "edad", "ciudad" → son las claves (los "nombres" con los que accedes)
#"Camila", 25, "Bogotá" → son los valores (los datos reales)

# Acceder a un valor — por clave, no por índice
print(persona["nombre"])   # Camila
print(persona["edad"])     # 25

# Modificar o agregar un valor
persona["edad"] = 26              # modifica un valor existente
persona["profesion"] = "Diseñadora"   # agrega una clave nueva
print(persona)

# Recorrer un diccionario con for

for clave in persona:
    print(clave, persona[clave])

#...

persona = {
    "nombre": "Camila",
    "edad": 25,
    "ciudad": "Bogotá"
}

print(persona["nombre"])
persona["edad"] = 26
persona["profesion"] = "Diseñadora"

for clave in persona:
    print(clave, persona[clave])